{
  "name": "@twc/branch-name-validation",
  "version": "1.3.0",
  "description": "A GitHub Action that enforces branch naming conventions on pull requests, with support for configurable regex patterns, Dependabot branch skipping, and optional PR review integration.",
  "author": "Christian Schou Køster",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc --noEmit && node ./scripts/build.js",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "24",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
